# Normalize line endings
* text=auto

# Main languages
*.rs   linguist-language=Rust
*.vue  linguist-language=Vue
*.ts   linguist-language=TypeScript
*.css  linguist-language=CSS
*.html linguist-language=HTML
*.py   linguist-language=Python

# Ignore generated/minified files
dist/** linguist-generated=true
*.min.js linguist-generated=true

# Ignore embedded/legacy codeview assets
public/code_view/** linguist-generated=true

# Ignore plain JS files for stats
*.js linguist-generated=true

# Ignore test output files
output.html linguist-generated=true

# Ignore dependencies
node_modules/** linguist-vendored
target/** linguist-vendored
