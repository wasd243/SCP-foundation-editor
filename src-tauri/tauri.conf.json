{
    "$schema": "https://schema.tauri.app/config/2",

    "productName": "SCP-WYSIWYG by wasd243",
    "version": "3.0.0-alpha.1",
    "identifier": "com.wasd243.scpwysiwyg",

    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:5173",

        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },

    "app": {
        "windows": [
            {
                "title": "SCP-WYSIWYG",
                "width": 1600,
                "height": 900,
                "resizable": true
            }
        ],

        "security": {
            "csp": null
        }
    },

    "bundle": {
        "active": true,
        "targets": "all",
        "icon": []
    }
}
