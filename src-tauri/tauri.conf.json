{
    "$schema": "https://schema.tauri.app/config/2",

    "productName": "SCP-WYSIWYG",
    "identifier": "com.wasd243.scpwysiwyg",

    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:5173",

        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },

    "app": {
        "withGlobalTauri": true,
        "macOSPrivateApi": true,
        "windows": [
            {
                "label": "main",
                "title": "SCP-WYSIWYG",
                "width": 1600,
                "height": 900,
                "resizable": true,
                "visible": false
            },
            {
                "label": "splashscreen",
                "url": "splashscreen.html",
                "width": 400,
                "height": 300,
                "decorations": false,
                "center": true,
                "resizable": false,
                "transparent": true,
                "alwaysOnTop": true
            }
        ],

        "security": {
            "csp": null
        }
    },

    "plugins": {
        "updater": {
            "endpoints": [
                "https://github.com/wasd243/SCP-foundation-editor/releases/latest/download/latest.json"
            ],
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMyQzdFNzQwN0I4MjBCMQpSV1N4SUxnSGRINHNET0ZIWmlLNTFKV0lFT0R1cUJGeG1maVZ0US9ZSDlLOUpJZllDTVpac2hqMwo="
        }
    },

    "bundle": {
        "active": true,
        "createUpdaterArtifacts": true,
        "targets": ["nsis", "app", "dmg", "deb", "appimage"],
        "icon": ["icons/icon.png", "icons/icon.ico", "icons/icon.icns"],
        "resources": {
            "../resourcepack/": "resourcepack/"
        }
    }
}
