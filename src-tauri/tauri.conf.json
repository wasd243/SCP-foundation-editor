{
    "$schema": "https://schema.tauri.app/config/2",

    "productName": "SCP-WYSIWYG by wasd243",
    "version": "3.0.0",
    "identifier": "com.wasd243.scpwysiwyg",

    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:5173",

        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },

    "app": {
        "macOSPrivateApi": true,
        "windows": [
            {
                "label": "main",
                "title": "SCP-WYSIWYG",
                "width": 1600,
                "height": 900,
                "resizable": true,
                "visible": false
            },
            {
                "label": "splashscreen",
                "url": "splashscreen.html",
                "width": 400,
                "height": 300,
                "decorations": false,
                "center": true,
                "resizable": false,
                "transparent": true,
                "alwaysOnTop": true
            }
        ],

        "security": {
            "csp": null
        }
    },

    "bundle": {
        "active": true,
        "targets": "all",
        "icon": ["icons/icon.png", "icons/icon.ico", "icons/icon.icns"]
    }
}
