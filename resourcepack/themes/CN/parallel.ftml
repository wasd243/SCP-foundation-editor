[[div style="position: relative; margin: auto; max-width: 30rem; background-color: rgb(254, 254, 254); border-radius: 1rem;"]]
[[image https://hormress.github.io/Parallel/images/parallel-theme-logo.svg style="padding: 1rem;"]]
[[div class="hover" style="position: absolute; width: 100%; height: 100%; left: 0; top: 0;"]]
