{
    "reference": {
        "type": "wjInlineTag",
        "attrs": {
            "tagName": "span",
            "htmlAttributes": {
                "class": "wj-footnote-ref"
            }
        },
        "content": [
            {
                "type": "wjInlineTag",
                "attrs": {
                    "tagName": "wj-footnote-ref-marker",
                    "htmlAttributes": {
                        "class": "wj-footnote-ref-marker",
                        "role": "link",
                        "aria-label": "Footnote __FOOTNOTE_ID__.",
                        "data-id": "__FOOTNOTE_ID__"
                    }
                },
                "content": [
                    {
                        "type": "text",
                        "text": "__FOOTNOTE_ID__"
                    }
                ]
            },
            {
                "type": "wjInlineTag",
                "attrs": {
                    "tagName": "span",
                    "htmlAttributes": {
                        "class": "wj-footnote-ref-tooltip",
                        "aria-hidden": "true"
                    }
                },
                "content": [
                    {
                        "type": "wjInlineTag",
                        "attrs": {
                            "tagName": "span",
                            "htmlAttributes": {
                                "class": "wj-footnote-ref-tooltip-label"
                            }
                        },
                        "content": [
                            {
                                "type": "text",
                                "text": "Footnote __FOOTNOTE_ID__."
                            }
                        ]
                    },
                    {
                        "type": "wjInlineTag",
                        "attrs": {
                            "tagName": "span",
                            "htmlAttributes": {
                                "class": "wj-footnote-ref-contents"
                            }
                        },
                        "content": [
                            {
                                "type": "text",
                                "text": "__FOOTNOTE_ID__"
                            }
                        ]
                    }
                ]
            }
        ]
    },
    "list": {
        "type": "wjBlockTag",
        "attrs": {
            "tagName": "div",
            "htmlAttributes": {
                "class": "wj-footnote-list"
            }
        },
        "content": [
            {
                "type": "wjTextBlockTag",
                "attrs": {
                    "tagName": "div",
                    "htmlAttributes": {
                        "class": "wj-title",
                        "contenteditable": "false"
                    }
                },
                "content": [
                    {
                        "type": "text",
                        "text": "Footnotes"
                    }
                ]
            },
            {
                "type": "wjBlockTag",
                "attrs": {
                    "tagName": "ol",
                    "htmlAttributes": {}
                }
            }
        ]
    },
    "orderedList": {
        "type": "wjBlockTag",
        "attrs": {
            "tagName": "ol",
            "htmlAttributes": {}
        }
    },
    "listItem": {
        "type": "wjTextBlockTag",
        "attrs": {
            "tagName": "li",
            "htmlAttributes": {
                "class": "wj-footnote-list-item",
                "data-id": "__FOOTNOTE_ID__"
            }
        },
        "content": [
            {
                "type": "wjInlineTag",
                "attrs": {
                    "tagName": "wj-footnote-list-item-marker",
                    "htmlAttributes": {
                        "class": "wj-footnote-list-item-marker",
                        "type": "button",
                        "role": "link",
                        "contenteditable": "false"
                    }
                },
                "content": [
                    {
                        "type": "text",
                        "text": "__FOOTNOTE_ID__"
                    },
                    {
                        "type": "wjInlineTag",
                        "attrs": {
                            "tagName": "span",
                            "htmlAttributes": {
                                "class": "wj-footnote-sep"
                            }
                        },
                        "content": [
                            {
                                "type": "text",
                                "text": "."
                            }
                        ]
                    }
                ]
            },
            {
                "type": "wjInlineTag",
                "attrs": {
                    "tagName": "span",
                    "htmlAttributes": {
                        "class": "wj-footnote-list-item-contents"
                    }
                }
            }
        ]
    }
}
